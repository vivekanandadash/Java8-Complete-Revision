package PredefinedFunctionalInterface;

import java.util.Arrays;
import java.util.List;
import java.util.concurrent.ForkJoinPool;
import java.util.function.Predicate;

// Q) Take a List of persons and print the person whose age is >=30 using lambda expression

class Person{
   public String name;
   public int age;
   public double salary;
   
   Person(String name , int age , double salary){
	   this.name = name;
	   this.age = age;
	   this.salary = salary;
   }
   
}

public class PredicatePersonsDemo {
	
public static void main(String[] args) {
	Person person0 = new Person("Alice",34 , 90000);
	Person person1 = new Person("Bob",24 , 80000);
	Person person2 = new Person("Charlie",37 , 70000);
	Person person3 = new Person("David",31 , 85000);
	Person person4 = new Person("Elice",29 , 65000);
	
	//Create a List
	List<Person> list = Arrays.asList(
			person0,
			person1,
			person2,
			person3,
			person4
			);

	
	// Use Lambda Function to filter the employee

	Predicate<Person> person  = p -> {
		return p.age>=30;
	};
	

	//Use forEach method to print filter persons

	for(Person filterPerson : list) {
		if (person.test((filterPerson) )) {
			System.out.println(list);
		}
	}

}





	

}
