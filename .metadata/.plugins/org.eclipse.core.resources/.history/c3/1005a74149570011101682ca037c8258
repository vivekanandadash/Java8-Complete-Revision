package functionFunctionalInterface;

import java.util.function.Function;

public class FunctionDemo {
public static void main(String[] args) {
	
	Function<String, Integer> personLength = (name)->{
		return name.length();
	};
	System.out.println(personLength.apply("Vivekananda"));
	System.out.println(personLength.getClass());
	if(personLength instanceof  Runnable) {
	System.out.println("yes it is runnable");
	}
	
  
}

}
