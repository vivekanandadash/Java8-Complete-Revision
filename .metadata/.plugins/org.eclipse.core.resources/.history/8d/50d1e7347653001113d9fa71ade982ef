package learningInterface;


interface Mobile{
	void call();
	default void camera() {
		System.out.println("Camera is on");
	}
}
class Samsung implements Mobile{

	public void call() {
		// TODO Auto-generated method stub
		System.out.println("Someone Is calling");
		
	}
	public void camera() {
		System.out.println("Camera is now off");
	}
	
}
public class Electronics {
	public static void main(String[] args) {
		Samsung s = new Samsung();
		s.call();
		s.camera();
	}

}
